# Copy this file to .env and fill in your values.
# The .env file is gitignored — never commit actual credentials.

# Required: SLUGGER API key — contact the SARG team or ALPB platform admins to obtain one.
SLUGGER_API_KEY=your-slugger-api-key-here

# Optional: override the API base URL (defaults to the ALPB production endpoint).
# SLUGGER_BASE_URL=https://1ywv9dczq5.execute-api.us-east-2.amazonaws.com/ALPBAPI

# Optional: override the port the local server listens on (defaults to 8080).
# PORT=8080
